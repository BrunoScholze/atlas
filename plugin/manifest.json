{
  "manifest_version": 3,
  "name": "autoCode",
  "version": "1.0.0",
  "description": "Analisa chamados do Jira e localiza problemas no código",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": [
    "https://*.atlassian.net/*",
    "https://*.totvs.com.br/*",
    "http://localhost:3000/*"
  ],
  "icons": {
    "16":  "icon.png",
    "32":  "icon.png",
    "48":  "icon.png",
    "128": "icon.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icon.png",
      "32":  "icon.png",
      "48":  "icon.png",
      "128": "icon.png"
    }
  },
  "content_scripts": [{
    "matches": [
      "https://*.atlassian.net/browse/*",
      "https://*.totvs.com.br/browse/*"
    ],
    "js": ["content.js"]
  }]
}
